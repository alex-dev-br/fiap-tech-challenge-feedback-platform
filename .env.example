# Azure Service Bus
FEEDBACK_SERVICEBUS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<key-name>;SharedAccessKey=<key>;EntityPath=<queue-name>
FEEDBACK_SERVICEBUS_QUEUE_NAME=<queue-name>
FEEDBACK_SERVICEBUS_NAMESPACE=<namespace>

# Database - variáveis próprias da aplicação
# Não usar QUARKUS_DATASOURCE_* aqui para não sobrescrever os testes com H2.
FEEDBACK_DB_KIND=postgresql
FEEDBACK_DB_URL=jdbc:postgresql://<db-host>:5432/postgres?sslmode=require
FEEDBACK_DB_USER=feedback
FEEDBACK_DB_PASSWORD=<password>

# E-mail / assunto
EMAIL_SUBJECT=Feedback de insatisfação recebido - FeedBack Platform